# Deployment-friendly npm configuration
# Disable package-lock for deployment consistency
package-lock=false

# Use npm cache efficiently
cache=/tmp/.npm-cache

# Configure registry and timeout settings
registry=https://registry.npmjs.org/
timeout=300000

# Node-gyp configuration for deployment environments
# Skip optional dependencies that require compilation
optional=false

# Rebuild native modules for current platform
rebuild=true

# Configure for CI/deployment environment
progress=false
loglevel=warn

# Skip scripts that might cause issues in deployment
ignore-scripts=false

# Configure node-gyp build settings
node_gyp_cache_lock_retries=10