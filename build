#!/bin/bash
# Deployment-compatible build script
set -e

echo "Building with deployment-compatible structure..."

# Clean previous build
rm -rf dist/

# Run vite build first
npx vite build

# Build server with correct output location
npx esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outfile=dist/server/index.js

# Create production package.json
cat > dist/package.json << 'EOF'
{
  "name": "leadapps-production",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node server/index.js"
  }
}
EOF

# Create uploads directory
mkdir -p dist/uploads

echo "Deployment build complete!"
echo "Structure:"
ls -la dist/server/index.js dist/package.json