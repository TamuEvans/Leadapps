#!/usr/bin/env node

/**
 * Production build script for Replit deployment
 * This script replaces the problematic npm run build command
 */

import { execSync } from 'child_process';
import { writeFileSync, existsSync, mkdirSync, rmSync } from 'fs';

console.log('🚀 Building for Replit deployment...');

try {
  // Clean previous build
  if (existsSync('dist')) {
    rmSync('dist', { recursive: true, force: true });
  }

  // Build frontend
  console.log('📦 Building frontend assets...');
  execSync('vite build', { stdio: 'inherit' });

  // Create server directory
  mkdirSync('dist/server', { recursive: true });

  // Build backend to correct location
  console.log('⚙️ Building backend...');
  execSync(
    'esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outfile=dist/server/index.js',
    { stdio: 'inherit' }
  );

  // Create production package.json with correct entry point
  const productionPackage = {
    "name": "rest-express-production",
    "version": "1.0.0", 
    "type": "module",
    "main": "server/index.js",
    "scripts": {
      "start": "node server/index.js"
    },
    "engines": {
      "node": ">=18.0.0"
    }
  };

  writeFileSync('dist/package.json', JSON.stringify(productionPackage, null, 2));

  // Verify required files exist
  const required = ['dist/server/index.js', 'dist/package.json', 'dist/public/index.html'];
  const missing = required.filter(f => !existsSync(f));
  
  if (missing.length > 0) {
    throw new Error(`Missing files: ${missing.join(', ')}`);
  }

  console.log('✅ Build complete! Structure:');
  console.log('   dist/server/index.js ← Backend entry point');
  console.log('   dist/package.json    ← Production config');
  console.log('   dist/public/         ← Frontend assets');

} catch (error) {
  console.error('❌ Build failed:', error.message);
  process.exit(1);
}