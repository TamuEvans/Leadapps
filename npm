#!/bin/bash

# NPM OVERRIDE SCRIPT
# This replaces npm commands to use our corrected build process

if [ "$1" = "run" ] && [ "$2" = "build" ]; then
    echo "🔧 Using corrected build process instead of npm run build..."
    exec /bin/bash ./correct-build.sh
else
    # Pass through to real npm for other commands
    exec /usr/bin/npm "$@"
fi