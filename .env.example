
# Database Connection (Required)
DATABASE_URL=postgresql://username:password@host:port/database?sslmode=require

# Security Configuration (Required)
SESSION_SECRET=your-32-character-secure-random-string
NODE_ENV=production
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# Email Service Configuration (Required for password reset)
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your-smtp-password
FROM_EMAIL=noreply@yourdomain.com

# Data Protection (Generate with: openssl rand -hex 32)
DATA_ENCRYPTION_KEY=your-64-character-hex-encryption-key

# Optional AI Services
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=your-anthropic-key

# Optional Payment Processing
STRIPE_SECRET_KEY=sk_live_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# File Upload Configuration
UPLOAD_MAX_SIZE=10485760

# OAuth Configuration (Optional)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
